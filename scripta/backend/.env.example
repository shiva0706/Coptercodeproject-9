# Copy this file to .env and fill in real values

# Secret used to sign JWT auth tokens - use a long random string in production
JWT_SECRET=Mystring12345

# Your own Groq API key, used for AI post generation.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional - your own xAI (Grok) API key, used for AI image generation.
# Different account from Groq above! Get one at https://x.ai/api
# If left blank, AI image generation falls back automatically to a free,
# no-signup image generator (Pollinations) - lower quality, but no setup.
XAI_API_KEY=

# Port the backend server listens on
PORT=4000

# --- Platform API credentials (all optional, only needed for real publishing) ---
# Each of these requires you to register a developer app with the platform.
# Until they're filled in, publishing is simulated (see services/publishService.js)

# X (Twitter) API v2 - https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn API - https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (Instagram/Facebook) Graph API - https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=

# TikTok Content Posting API - https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube Data API (Google Cloud) - https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Bluesky - uses an App Password, not OAuth. NOTE: this is the only platform
# with real publishing already wired up (see services/publishService.js) -
# fill these in and it goes live immediately. Everything else on this list
# is simulated regardless of credentials, until each integration is built.
# Create an App Password at https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Discord - https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# Reddit API - https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Pinterest API - https://developers.pinterest.com/
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Tumblr API - https://www.tumblr.com/oauth/apps
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=

# Threads API (via Meta) - https://developers.facebook.com/docs/threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# Snapchat Marketing/Snap Kit API - https://developers.snap.com/
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=